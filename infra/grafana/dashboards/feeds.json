{
  "uid": "sablebot-feeds",
  "title": "SableBot Feeds",
  "description": "Feed polling, notification, and platform API metrics for SableBot",
  "tags": [
    "sablebot",
    "feeds"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
