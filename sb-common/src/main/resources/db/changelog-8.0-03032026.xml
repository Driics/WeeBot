<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <!-- Create moderation_case table -->
    <changeSet id="8.0-03032026-1" author="driics">
        <createTable tableName="moderation_case">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_moderation_case"/>
            </column>
            <column name="version" type="BIGINT"/>
            <column name="guild_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="case_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="action_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="moderator_id" type="VARCHAR(21)">
                <constraints nullable="false"/>
            </column>
            <column name="moderator_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="target_id" type="VARCHAR(21)">
                <constraints nullable="false"/>
            </column>
            <column name="target_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="TEXT"/>
            <column name="duration" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="8.0-03032026-2" author="driics">
        <addUniqueConstraint tableName="moderation_case"
                             columnNames="guild_id, case_number"
                             constraintName="uk_moderation_case_guild_case_number"/>
        <createIndex indexName="idx_moderation_case_guild_target" tableName="moderation_case">
            <column name="guild_id" type="BIGINT"/>
            <column name="target_id" type="VARCHAR(21)"/>
        </createIndex>
    </changeSet>

    <!-- Create warn_escalation_rule table -->
    <changeSet id="8.0-03032026-3" author="driics">
        <createTable tableName="warn_escalation_rule">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_warn_escalation_rule"/>
            </column>
            <column name="version" type="BIGINT"/>
            <column name="config_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="threshold" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="action_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="duration" type="BIGINT"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="warn_escalation_rule"
                                 baseColumnNames="config_id"
                                 constraintName="fk_warn_escalation_rule_config"
                                 referencedTableName="mod_config"
                                 referencedColumnNames="id"/>
    </changeSet>

    <!-- Create automod_config table -->
    <changeSet id="8.0-03032026-4" author="driics">
        <createTable tableName="automod_config">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_automod_config"/>
            </column>
            <column name="version" type="BIGINT"/>
            <column name="guild_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <!-- Anti-Spam -->
            <column name="anti_spam_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="anti_spam_max_messages" type="INTEGER" defaultValueNumeric="5">
                <constraints nullable="false"/>
            </column>
            <column name="anti_spam_window_seconds" type="INTEGER" defaultValueNumeric="5">
                <constraints nullable="false"/>
            </column>
            <column name="anti_spam_action" type="VARCHAR(20)" defaultValue="MUTE">
                <constraints nullable="false"/>
            </column>
            <column name="anti_spam_mute_duration" type="BIGINT" defaultValueNumeric="300000"/>
            <!-- Anti-Raid -->
            <column name="anti_raid_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="anti_raid_join_threshold" type="INTEGER" defaultValueNumeric="10">
                <constraints nullable="false"/>
            </column>
            <column name="anti_raid_window_seconds" type="INTEGER" defaultValueNumeric="10">
                <constraints nullable="false"/>
            </column>
            <column name="anti_raid_min_account_age_days" type="INTEGER" defaultValueNumeric="7">
                <constraints nullable="false"/>
            </column>
            <column name="anti_raid_action" type="VARCHAR(20)" defaultValue="KICK">
                <constraints nullable="false"/>
            </column>
            <!-- Word Filter -->
            <column name="word_filter_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="word_filter_patterns" type="JSONB"/>
            <column name="word_filter_action" type="VARCHAR(20)" defaultValue="DELETE">
                <constraints nullable="false"/>
            </column>
            <!-- Link Filter -->
            <column name="link_filter_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="link_filter_mode" type="VARCHAR(20)" defaultValue="BLACKLIST">
                <constraints nullable="false"/>
            </column>
            <column name="link_filter_domains" type="JSONB"/>
            <column name="link_filter_action" type="VARCHAR(20)" defaultValue="DELETE">
                <constraints nullable="false"/>
            </column>
            <!-- Mention Spam -->
            <column name="mention_spam_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="mention_spam_threshold" type="INTEGER" defaultValueNumeric="5">
                <constraints nullable="false"/>
            </column>
            <column name="mention_spam_action" type="VARCHAR(20)" defaultValue="WARN">
                <constraints nullable="false"/>
            </column>
            <!-- General -->
            <column name="dm_on_action" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Add modlog_channel_id to mod_config -->
    <changeSet id="8.0-03032026-5" author="driics">
        <addColumn tableName="mod_config">
            <column name="modlog_channel_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
