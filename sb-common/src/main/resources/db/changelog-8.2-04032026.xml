<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="8.2-1" author="sablebot">
        <createTable tableName="api_key">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="guild_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="hashed_key" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="key_prefix" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="scopes" type="JSONB"/>
            <column name="created_by" type="VARCHAR(21)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="last_used_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="revoked" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="api_key" indexName="idx_api_key_guild_id">
            <column name="guild_id"/>
        </createIndex>

        <createIndex tableName="api_key" indexName="idx_api_key_hashed_key">
            <column name="hashed_key"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
